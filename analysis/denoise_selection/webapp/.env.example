APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
MAX_UPLOAD_MB=64
APP_DATA_DIR=analysis/denoise_selection/webapp/data
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
VITE_API_BASE_URL=http://127.0.0.1:8000

# DeepFilterNet3 (required for method=deepfilter)
# Use the conda env where deepfilternet + libdf are installed (same as local DFN3 tests).
DEEPFILTER_CONDA_ENV=dfnet311
# Optional: full path to model folder (default: analysis/denoise_selection/models/DeepFilterNet3)
# DEEPFILTER_MODEL_DIR=
# Optional: full path to deepFilter.exe instead of conda
# DEEPFILTER_CLI=

